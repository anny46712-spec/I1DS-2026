//Classifique a idade: criança, adolescente, adulto e idoso
function classificarIdade(idade) {
  if (idade < 12) {
    return "Criança";
  } else if (idade < 18) {
    return "Adolescente";
  } else if (idade < 60) {
    return "Adulto";
  } else {
    return "Idoso";
  }
}
console.log(classificarIdade(8));   
console.log(classificarIdade(17));  
console.log(classificarIdade(47));  
console.log(classificarIdade(80));  
console.log("--------------------------------------");

