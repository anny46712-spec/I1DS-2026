//Dado um mês, informe o trimestre
function trimestreDoMes(mes) {
  if (mes >= 1 && mes <= 3) {
    return "1º trimestre";
  } else if (mes >= 4 && mes <= 6) {
    return "2º trimestre";
  } else if (mes >= 7 && mes <= 9) {
    return "3º trimestre";
  } else if (mes >= 10 && mes <= 12) {
    return "4º trimestre";
  } else {
    return "Mês inválido";
  }
}
console.log(trimestreDoMes(8));   
